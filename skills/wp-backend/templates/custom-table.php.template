namespace {{NAMESPACE}}\Database;

// Exit if accessed directly.
if ( ! defined( 'ABSPATH' ) ) {
	exit;
}

/**
 * {{CLASS_NAME}} class.
 *
 * Manages the {{TABLE_NAME}} custom database table.
 */
class {{CLASS_NAME}} {

	/**
	 * Table version.
	 *
	 * Increment this when making schema changes to trigger dbDelta().
	 *
	 * @var string
	 */
	const VERSION = '{{TABLE_VERSION}}';

	/**
	 * Table name without prefix.
	 *
	 * @var string
	 */
	const TABLE_NAME = '{{TABLE_NAME}}';

	/**
	 * Option name for storing table version.
	 *
	 * @var string
	 */
	const VERSION_OPTION = '{{VERSION_OPTION_NAME}}';

	/**
	 * Get the full table name with WordPress prefix.
	 *
	 * @return string Full table name.
	 */
	public static function get_table_name(): string {
		global $wpdb;
		return $wpdb->prefix . '{{PLUGIN_PREFIX}}_' . self::TABLE_NAME;
	}

	/**
	 * Create the database table.
	 *
	 * Uses dbDelta() for safe table creation and updates.
	 * CRITICAL: dbDelta() requires specific SQL formatting.
	 *
	 * @return void
	 */
	public static function create_table(): void {
		global $wpdb;

		$table_name      = self::get_table_name();
		$charset_collate = $wpdb->get_charset_collate();

		// CRITICAL: dbDelta() formatting rules:
		// 1. TWO spaces after PRIMARY KEY.
		// 2. Space after KEY name before parenthesis.
		// 3. Each column on its own line.
		// 4. No trailing comma before closing parenthesis.
		$sql = "CREATE TABLE $table_name (
{{COLUMN_DEFINITIONS}}
{{INDEX_DEFINITIONS}}
		) $charset_collate;";

		require_once ABSPATH . 'wp-admin/includes/upgrade.php';
		dbDelta( $sql );
	}

	/**
	 * Check and update table if version has changed.
	 *
	 * Call this on 'plugins_loaded' hook to handle schema updates.
	 *
	 * @return void
	 */
	public static function maybe_update_table(): void {
		$installed_version = get_option( self::VERSION_OPTION, '0' );

		if ( version_compare( $installed_version, self::VERSION, '<' ) ) {
			self::create_table();
			update_option( self::VERSION_OPTION, self::VERSION );
		}
	}

	/**
	 * Drop the database table.
	 *
	 * WARNING: This permanently deletes the table and all data.
	 * Only call from uninstall.php.
	 *
	 * @return void
	 */
	public static function drop_table(): void {
		global $wpdb;

		$table_name = self::get_table_name();

		// phpcs:ignore WordPress.DB.DirectDatabaseQuery.DirectQuery, WordPress.DB.DirectDatabaseQuery.NoCaching, WordPress.DB.DirectDatabaseQuery.SchemaChange
		$wpdb->query( "DROP TABLE IF EXISTS $table_name" );
		delete_option( self::VERSION_OPTION );
	}

	/**
	 * Check if table exists.
	 *
	 * @return bool True if table exists.
	 */
	public static function table_exists(): bool {
		global $wpdb;

		$table_name = self::get_table_name();

		// phpcs:ignore WordPress.DB.DirectDatabaseQuery.DirectQuery, WordPress.DB.DirectDatabaseQuery.NoCaching
		$result = $wpdb->get_var(
			$wpdb->prepare( 'SHOW TABLES LIKE %s', $table_name )
		);

		return $result === $table_name;
	}

{{MULTISITE_METHODS}}
}

