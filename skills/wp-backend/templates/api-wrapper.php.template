// WITH_RETRY:
		$attempts = 0;
		$response = null;

		while ( $attempts < self::MAX_RETRIES ) {
			$response = wp_remote_request( $url, $args );
			++$attempts;

			if ( ! $this->should_retry( $response ) ) {
				break;
			}

			// Exponential backoff.
			if ( $attempts < self::MAX_RETRIES ) {
				sleep( pow( 2, $attempts - 1 ) );
			}
		}

// WITHOUT_RETRY:
		$response = wp_remote_request( $url, $args );

		if ( is_wp_error( $response ) ) {
			return $response;
		}

