		if ( ! empty( $params['{{PARAM_NAME}}'] ) && ! filter_var( $params['{{PARAM_NAME}}'], FILTER_VALIDATE_URL ) ) {
			$errors['{{PARAM_NAME}}'] = __( 'Please enter a valid URL.', '{{TEXT_DOMAIN}}' );
		}

// MIN_LENGTH:
		if ( strlen( $params['{{PARAM_NAME}}'] ) < {{MIN_LENGTH}} ) {
