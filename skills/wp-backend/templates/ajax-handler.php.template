		if ( empty( $params['{{PARAM_NAME}}'] ) ) {
			$errors['{{PARAM_NAME}}'] = __( '{{PARAM_LABEL}} is required.', '{{TEXT_DOMAIN}}' );
		}

// REQUIRED_INTEGER:
		if ( 0 === $params['{{PARAM_NAME}}'] ) {
			$errors['{{PARAM_NAME}}'] = __( '{{PARAM_LABEL}} is required.', '{{TEXT_DOMAIN}}' );
		}

// VALID_EMAIL:
		if ( ! empty( $params['{{PARAM_NAME}}'] ) && ! is_email( $params['{{PARAM_NAME}}'] ) ) {
			$errors['{{PARAM_NAME}}'] = __( 'Please enter a valid email address.', '{{TEXT_DOMAIN}}' );
		}

