		$params['{{PARAM_NAME}}'] = ( isset( $_POST['{{PARAM_NAME}}'] ) && is_array( $_POST['{{PARAM_NAME}}'] ) ) ? array_map( 'sanitize_text_field', wp_unslash( $_POST['{{PARAM_NAME}}'] ) ) : array();

