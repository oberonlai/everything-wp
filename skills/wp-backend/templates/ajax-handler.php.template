	public static function register(): void {
{{AJAX_HOOKS}}
	}

	/**
	 * Handle the AJAX request.
	 *
	 * @return void
	 */
	public static function handle(): void {
		// Verify nonce.
		if ( ! self::verify_nonce() ) {
			self::send_error(
				__( 'Security check failed.', '{{TEXT_DOMAIN}}' ),
				'invalid_nonce',
				403
			);
		}

		// Check permissions.
		if ( ! self::check_permissions() ) {
			self::send_error(
				__( 'You do not have permission to perform this action.', '{{TEXT_DOMAIN}}' ),
				'insufficient_permissions',
				403
			);
		}

		// Get and validate parameters.
		$params = self::get_parameters();
		$errors = self::validate( $params );

		if ( ! empty( $errors ) ) {
			self::send_error(
				__( 'Validation failed.', '{{TEXT_DOMAIN}}' ),
				'validation_error',
				400,
				array( 'errors' => $errors )
			);
		}

		// Process the request.
		$result = self::process( $params );

		if ( is_wp_error( $result ) ) {
			self::send_error(
				$result->get_error_message(),
				$result->get_error_code(),
				400
			);
		}

		self::send_success( $result );
	}

	/**
	 * Verify nonce.
	 *
	 * @return bool True if nonce is valid.
	 */
	private static function verify_nonce(): bool {
		$nonce = ( isset( $_POST['nonce'] ) ) ? sanitize_text_field( wp_unslash( $_POST['nonce'] ) ) : '';

		return wp_verify_nonce( $nonce, self::NONCE_ACTION );
	}

	/**
	 * Check user permissions.
	 *
	 * @return bool True if user has permission.
	 */
	private static function check_permissions(): bool {
{{PERMISSION_CHECK}}
	}

	/**
	 * Get and sanitize request parameters.
	 *
	 * @return array Sanitized parameters.
	 */
	private static function get_parameters(): array {
		$params = array();

{{PARAMETER_SANITIZATION}}

		return $params;
	}

	/**
	 * Validate parameters.
	 *
	 * @param array $params Parameters to validate.
	 * @return array Validation errors (empty if valid).
	 */
	private static function validate( array $params ): array {
		$errors = array();

{{PARAMETER_VALIDATION}}

		return $errors;
	}

	/**
	 * Process the request.
	 *
	 * @param array $params Validated parameters.
	 * @return array|\WP_Error Result data or WP_Error on failure.
	 */
	private static function process( array $params ) {
		// TODO: Implement your business logic here.
		// Example:
		// $repository = new \{{NAMESPACE}}\Repository\{{REPOSITORY_CLASS}}();
		// return $repository->create( $params );

		return array(
			'message' => __( 'Request processed successfully.', '{{TEXT_DOMAIN}}' ),
			'data'    => $params,
		);
	}

	/**
	 * Send success response.
	 *
	 * @param array $data Response data.
	 * @return void
	 */
	private static function send_success( array $data ): void {
		wp_send_json_success( $data );
	}

	/**
	 * Send error response.
	 *
	 * @param string $message    Error message.
	 * @param string $code       Error code.
	 * @param int    $status     HTTP status code.
	 * @param array  $extra_data Additional data.
	 * @return void
	 */
	private static function send_error(
		string $message,
		string $code = 'error',
		int $status = 400,
		array $extra_data = array()
	): void {
		$data = array_merge(
			array(
				'code'    => $code,
				'message' => $message,
			),
			$extra_data
		);

		wp_send_json_error( $data, $status );
	}

	/**
	 * Get nonce for JavaScript.
	 *
	 * @return string Nonce value.
	 */
	public static function get_nonce(): string {
		return wp_create_nonce( self::NONCE_ACTION );
	}

	/**
	 * Get localization data for JavaScript.
	 *
	 * @return array Localization data.
	 */
	public static function get_localize_data(): array {
		return array(
			'ajax_url' => admin_url( 'admin-ajax.php' ),
			'action'   => self::ACTION,
			'nonce'    => self::get_nonce(),
		);
	}
}

