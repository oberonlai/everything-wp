	/**
	 * Prepare items for display.
	 *
	 * @return void
	 */
	public function prepare_items(): void {
		$columns  = $this->get_columns();
		$hidden   = array();
		$sortable = $this->get_sortable_columns();

		$this->_column_headers = array( $columns, $hidden, $sortable );

		// Process bulk actions.
		$this->process_bulk_action();

		// Get parameters.
		$per_page     = $this->get_items_per_page( '{{PLUGIN_PREFIX}}_{{PLURAL}}_per_page', 20 );
		$current_page = $this->get_pagenum();
		$orderby      = ( isset( $_REQUEST['orderby'] ) ) ? sanitize_text_field( wp_unslash( $_REQUEST['orderby'] ) ) : 'id';
		$order        = ( isset( $_REQUEST['order'] ) ) ? sanitize_text_field( wp_unslash( $_REQUEST['order'] ) ) : 'DESC';

		// Get search query.
		$search = ( isset( $_REQUEST['s'] ) ) ? sanitize_text_field( wp_unslash( $_REQUEST['s'] ) ) : '';

		// Get status filter.
		$status = ( isset( $_REQUEST['status'] ) ) ? sanitize_text_field( wp_unslash( $_REQUEST['status'] ) ) : '';

		// Build where conditions.
		$where = array();
		if ( ! empty( $status ) ) {
			$where['status'] = $status;
		}

		// TODO: Replace with your repository calls.
		// $items = $this->repository->get_all( $where, $orderby, $order, $per_page, ($current_page - 1) * $per_page );
		// $total_items = $this->repository->count( $where );

		// Placeholder data.
		$items       = array();
		$total_items = 0;

		$this->items = $items;

		$this->set_pagination_args(
			array(
				'total_items' => $total_items,
				'per_page'    => $per_page,
				'total_pages' => ceil( $total_items / $per_page ),
			)
		);
	}

	/**
	 * Default column renderer.
	 *
	 * @param object $item        Current item.
	 * @param string $column_name Column name.
	 * @return string Column output.
	 */
	protected function column_default( $item, $column_name ): string {
		if ( isset( $item->$column_name ) ) {
			return esc_html( $item->$column_name );
		}

		return '';
	}

	/**
	 * Checkbox column.
	 *
	 * @param object $item Current item.
	 * @return string Checkbox HTML.
	 */
	protected function column_cb( $item ): string {
		return sprintf(
			'<input type="checkbox" name="{{SINGULAR}}_ids[]" value="%d" />',
			$item->id
		);
	}

	/**
	 * Title column with row actions.
	 *
	 * @param object $item Current item.
	 * @return string Column output with actions.
	 */
	protected function column_title( $item ): string {
		$edit_url   = admin_url( sprintf( 'admin.php?page={{PLUGIN_PREFIX}}-{{SINGULAR}}-edit&id=%d', $item->id ) );
		$delete_url = wp_nonce_url(
			admin_url( sprintf( 'admin.php?page={{PLUGIN_PREFIX}}-{{PLURAL}}&action=delete&{{SINGULAR}}_ids[]=%d', $item->id ) ),
			'bulk-{{PLURAL}}'
		);

		$actions = array(
			'edit'   => sprintf( '<a href="%s">%s</a>', esc_url( $edit_url ), __( 'Edit', '{{TEXT_DOMAIN}}' ) ),
			'delete' => sprintf( '<a href="%s" onclick="return confirm(\'%s\');">%s</a>', esc_url( $delete_url ), esc_js( __( 'Are you sure?', '{{TEXT_DOMAIN}}' ) ), __( 'Delete', '{{TEXT_DOMAIN}}' ) ),
		);

		return sprintf(
			'<strong><a href="%s">%s</a></strong>%s',
			esc_url( $edit_url ),
			esc_html( $item->title ),
			$this->row_actions( $actions )
		);
	}

