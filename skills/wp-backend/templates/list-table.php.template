// COLUMN_METHOD_STATUS:
	/**
	 * Status column.
	 *
	 * @param object $item Current item.
	 * @return string Status badge HTML.
	 */
	protected function column_status( $item ): string {
		$status_labels = array(
			'pending'   => __( 'Pending', '{{TEXT_DOMAIN}}' ),
			'active'    => __( 'Active', '{{TEXT_DOMAIN}}' ),
			'completed' => __( 'Completed', '{{TEXT_DOMAIN}}' ),
		);

		$status = isset( $item->status ) ? $item->status : 'pending';
		$label  = isset( $status_labels[ $status ] ) ? $status_labels[ $status ] : $status;

		return sprintf(
			'<span class="status-badge status-%s">%s</span>',
			esc_attr( $status ),
			esc_html( $label )
		);
	}

// COLUMN_METHOD_DATE:
	/**
	 * Date column.
	 *
	 * @param object $item Current item.
	 * @return string Formatted date.
	 */
	protected function column_{{COLUMN_KEY}}( $item ): string {
		if ( empty( $item->{{COLUMN_KEY}} ) ) {
			return '—';
		}

		return esc_html(
			date_i18n(
				get_option( 'date_format' ) . ' ' . get_option( 'time_format' ),
				strtotime( $item->{{COLUMN_KEY}} )
			)
		);
	}

// COLUMN_METHOD_USER:
	/**
	 * User column.
	 *
	 * @param object $item Current item.
	 * @return string User display name.
	 */
	protected function column_user_id( $item ): string {
		if ( empty( $item->user_id ) ) {
			return '—';
		}

		$user = get_userdata( $item->user_id );

		if ( ! $user ) {
			return __( 'Unknown', '{{TEXT_DOMAIN}}' );
		}

		return esc_html( $user->display_name );
	}

// COLUMN_METHOD_AMOUNT:
	/**
	 * Amount column.
	 *
	 * @param object $item Current item.
	 * @return string Formatted amount.
	 */
	protected function column_amount( $item ): string {
		if ( ! isset( $item->amount ) ) {
			return '—';
		}

		return esc_html( number_format_i18n( $item->amount, 2 ) );
	}

