	/**
	 * Process bulk actions.
	 *
	 * @return void
	 */
	public function process_bulk_action(): void {
		// Check nonce.
		if ( isset( $_REQUEST['_wpnonce'] ) ) {
			$nonce = sanitize_text_field( wp_unslash( $_REQUEST['_wpnonce'] ) );
			if ( ! wp_verify_nonce( $nonce, 'bulk-{{PLURAL}}' ) ) {
				return;
			}
		} else {
			return;
		}

		// Get selected IDs.
		$ids = ( isset( $_REQUEST['{{SINGULAR}}_ids'] ) ) ? array_map( 'absint', $_REQUEST['{{SINGULAR}}_ids'] ) : array();

		if ( empty( $ids ) ) {
			return;
		}

		$action = $this->current_action();

		switch ( $action ) {
			case 'delete':
				foreach ( $ids as $id ) {
					// $this->repository->delete( $id );
				}
				$message = __( 'Items deleted.', '{{TEXT_DOMAIN}}' );
				break;

{{BULK_ACTION_CASES}}

			default:
				return;
		}

		// Redirect with success message.
		wp_safe_redirect(
			add_query_arg(
				array(
					'page'    => '{{PLUGIN_PREFIX}}-{{PLURAL}}',
					'message' => rawurlencode( $message ),
				),
				admin_url( 'admin.php' )
			)
		);
		exit;
	}

