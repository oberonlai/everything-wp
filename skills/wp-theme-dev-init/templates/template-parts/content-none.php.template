<?php
/**
 * Template part shown when no posts are found.
 *
 * @package {{THEME_NAME}}
 */

?>
<section class="no-results not-found">
	<header class="page-header">
		<h1 class="page-title"><?php esc_html_e( 'Nothing Found', '{{TEXT_DOMAIN}}' ); ?></h1>
	</header><!-- .page-header -->

	<div class="page-content">
		<?php if ( is_search() ) : ?>
			<p><?php esc_html_e( 'Sorry, but nothing matched your search terms. Please try again with different keywords.', '{{TEXT_DOMAIN}}' ); ?></p>
		<?php else : ?>
			<p><?php esc_html_e( 'It seems we can&rsquo;t find what you&rsquo;re looking for. Perhaps searching can help.', '{{TEXT_DOMAIN}}' ); ?></p>
		<?php endif; ?>

		<?php get_search_form(); ?>
	</div><!-- .page-content -->
</section><!-- .no-results -->
