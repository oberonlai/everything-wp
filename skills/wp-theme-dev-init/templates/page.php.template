<?php
/**
 * The template for displaying all single pages.
 *
 * @package {{THEME_NAME}}
 */

get_header();
?>

<main id="primary" class="site-main">
	<?php
	while ( have_posts() ) {
		the_post();

		get_template_part( 'template-parts/content', 'page' );

		// Load the comment template when comments are open or there is at least one comment.
		if ( comments_open() || get_comments_number() ) {
			comments_template();
		}
	}
	?>
</main><!-- #primary -->

<?php
get_sidebar();
get_footer();
