<?php
/**
 * PHPUnit bootstrap file for the {{THEME_NAME}} theme.
 *
 * Registers and activates this theme so template functions resolve during tests.
 *
 * @package {{THEME_NAME}}
 */

$_tests_dir = getenv( 'WP_TESTS_DIR' );

if ( ! $_tests_dir ) {
	$_tests_dir = rtrim( sys_get_temp_dir(), '/\\' ) . '/wordpress-tests-lib';
}

// Forward the custom PHPUnit Polyfills path to the WordPress test suite.
$_phpunit_polyfills_path = getenv( 'WP_TESTS_PHPUNIT_POLYFILLS_PATH' );
if ( false !== $_phpunit_polyfills_path ) {
	define( 'WP_TESTS_PHPUNIT_POLYFILLS_PATH', $_phpunit_polyfills_path );
}

if ( ! file_exists( "{$_tests_dir}/includes/functions.php" ) ) {
	// phpcs:ignore WordPress.Security.EscapeOutput.OutputNotEscaped
	echo "Could not find {$_tests_dir}/includes/functions.php, have you run bin/install-wp-tests.sh ?" . PHP_EOL;
	exit( 1 );
}

// Give access to the tests_add_filter() function.
require_once "{$_tests_dir}/includes/functions.php";

/**
 * Register this theme's directory and make it the active theme for the test run.
 *
 * @return void
 */
function _register_theme() {
	$theme_dir     = dirname( __DIR__ );
	$current_theme = basename( $theme_dir );
	$theme_root    = dirname( $theme_dir );

	// Point the theme root at the parent directory of this theme.
	add_filter(
		'theme_root',
		function () use ( $theme_root ) {
			return $theme_root;
		}
	);

	register_theme_directory( $theme_root );

	// Force this theme to be the active template and stylesheet.
	add_filter(
		'pre_option_template',
		function () use ( $current_theme ) {
			return $current_theme;
		}
	);
	add_filter(
		'pre_option_stylesheet',
		function () use ( $current_theme ) {
			return $current_theme;
		}
	);
}
tests_add_filter( 'muplugins_loaded', '_register_theme' );

// Start up the WordPress testing environment.
require "{$_tests_dir}/includes/bootstrap.php";
