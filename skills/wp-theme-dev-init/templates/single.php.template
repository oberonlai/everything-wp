<?php
/**
 * The template for displaying all single posts.
 *
 * @package {{THEME_NAME}}
 */

get_header();
?>

<main id="primary" class="site-main">
	<?php
	while ( have_posts() ) {
		the_post();

		get_template_part( 'template-parts/content', 'single' );

		// Load the comment template when comments are open or there is at least one comment.
		if ( comments_open() || get_comments_number() ) {
			comments_template();
		}

		the_post_navigation(
			array(
				'prev_text' => '<span class="nav-subtitle">' . esc_html__( 'Previous:', '{{TEXT_DOMAIN}}' ) . '</span> <span class="nav-title">%title</span>',
				'next_text' => '<span class="nav-subtitle">' . esc_html__( 'Next:', '{{TEXT_DOMAIN}}' ) . '</span> <span class="nav-title">%title</span>',
			)
		);
	}
	?>
</main><!-- #primary -->

<?php
get_sidebar();
get_footer();
