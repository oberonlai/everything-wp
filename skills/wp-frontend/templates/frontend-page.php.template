	/**
	 * Enqueue frontend assets.
	 *
	 * @return void
	 */
	private static function enqueue_assets(): void {
		if ( self::$assets_enqueued ) {
			return;
		}

{{ENQUEUE_ASSETS}}

		self::$assets_enqueued = true;
	}

	/**
	 * Render the shortcode content.
	 *
