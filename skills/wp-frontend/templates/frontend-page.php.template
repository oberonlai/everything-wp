/**
 * {{PAGE_NAME}} JavaScript
 *
 * @package {{NAMESPACE}}
 */

(function($) {
	'use strict';

	var {{PLUGIN_PREFIX}}_{{SHORTCODE_TAG}} = {

		/**
		 * Initialize.
		 */
		init: function() {
			this.bindEvents();
		},

		/**
		 * Bind events.
		 */
		bindEvents: function() {
			$('#{{PLUGIN_PREFIX}}-{{SHORTCODE_TAG}}-form').on('submit', this.handleSubmit.bind(this));
		},

		/**
		 * Handle form submission.
		 *
		 * @param {Event} e Submit event.
		 */
		handleSubmit: function(e) {
			e.preventDefault();

			var $form = $(e.target);
			var $button = $form.find('button[type="submit"]');
			var $messages = $form.find('.{{PLUGIN_PREFIX}}-form-messages');

			// Disable button.
			$button.prop('disabled', true).text({{PLUGIN_PREFIX}}_{{SHORTCODE_TAG}}.i18n.loading);

			// Clear messages.
			$messages.empty();

			// Collect form data.
			var formData = $form.serialize();
			formData += '&action={{AJAX_ACTION}}';
			formData += '&nonce=' + {{PLUGIN_PREFIX}}_{{SHORTCODE_TAG}}.nonce;

			// Send AJAX request.
			$.ajax({
				url: {{PLUGIN_PREFIX}}_{{SHORTCODE_TAG}}.ajax_url,
				type: 'POST',
				data: formData,
				success: function(response) {
					if (response.success) {
						$messages.html('<div class="{{PLUGIN_PREFIX}}-message {{PLUGIN_PREFIX}}-message-success">' + {{PLUGIN_PREFIX}}_{{SHORTCODE_TAG}}.i18n.success + '</div>');
						$form[0].reset();
					} else {
						$messages.html('<div class="{{PLUGIN_PREFIX}}-message {{PLUGIN_PREFIX}}-message-error">' + response.data.message + '</div>');
					}
				},
				error: function() {
					$messages.html('<div class="{{PLUGIN_PREFIX}}-message {{PLUGIN_PREFIX}}-message-error">' + {{PLUGIN_PREFIX}}_{{SHORTCODE_TAG}}.i18n.error + '</div>');
				},
				complete: function() {
					$button.prop('disabled', false).text('Submit');
				}
			});
		}
	};

	// Initialize on document ready.
	$(document).ready(function() {
		{{PLUGIN_PREFIX}}_{{SHORTCODE_TAG}}.init();
	});

})(jQuery);
