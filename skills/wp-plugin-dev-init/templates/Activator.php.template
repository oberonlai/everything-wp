/**
 * Activator class.
 *
 * This class handles all tasks that need to run during plugin activation.
 */
class Activator {

	/**
	 * Activate the plugin.
	 *
	 * This method is called when the plugin is activated.
	 * Add your activation logic here, such as:
	 * - Creating database tables
	 * - Setting default options
	 * - Scheduling cron jobs
	 * - Flushing rewrite rules
	 *
	 * @return void
	 */
	public static function activate(): void {
		// Check minimum PHP version.
		if ( version_compare( phpversion(), '{{REQUIRES_PHP}}', '<' ) ) {
			deactivate_plugins( plugin_basename( {{PLUGIN_PREFIX}}_PLUGIN_FILE ) );
			wp_die(
				esc_html__( 'This plugin requires PHP {{REQUIRES_PHP}} or higher.', '{{TEXT_DOMAIN}}' ),
				esc_html__( 'Plugin Activation Error', '{{TEXT_DOMAIN}}' ),
				array( 'back_link' => true )
			);
		}

		// Check minimum WordPress version.
		if ( version_compare( get_bloginfo( 'version' ), '{{REQUIRES_WP}}', '<' ) ) {
			deactivate_plugins( plugin_basename( {{PLUGIN_PREFIX}}_PLUGIN_FILE ) );
			wp_die(
				esc_html__( 'This plugin requires WordPress {{REQUIRES_WP}} or higher.', '{{TEXT_DOMAIN}}' ),
				esc_html__( 'Plugin Activation Error', '{{TEXT_DOMAIN}}' ),
				array( 'back_link' => true )
			);
		}

		// Set default options.
		self::set_default_options();

		// Create database tables if needed.
		self::create_tables();

		// Schedule cron jobs if needed.
		self::schedule_events();

		// Flush rewrite rules.
		flush_rewrite_rules();

		// Store plugin version for future upgrades.
		update_option( '{{PLUGIN_FUNCTION_PREFIX}}_version', Bootstrap::VERSION );

		// Trigger activation hook for other plugins/themes to hook into.
		do_action( '{{PLUGIN_FUNCTION_PREFIX}}_activated' );
	}

	/**
	 * Set default plugin options.
	 *
	 * @return void
	 */
	private static function set_default_options(): void {
		// Example: Set default options if they don't exist.
		$defaults = array(
			'enabled' => true,
		);

		if ( false === get_option( '{{PLUGIN_FUNCTION_PREFIX}}_settings' ) ) {
			add_option( '{{PLUGIN_FUNCTION_PREFIX}}_settings', $defaults );
		}
	}

